# Copy this file to .env.local and fill in your MongoDB connection string.
# On Vercel, add MONGODB_URI as a project environment variable instead.

# Full MongoDB connection URI (MongoDB Atlas or self-hosted).
# The app will use the database specified in the URI and store links in the "dsc" collection.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/myDatabase?retryWrites=true&w=majority
