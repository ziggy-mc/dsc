# MongoDB connection string – required for persistent short-link storage.
#
# Set up:
#   1. Create a MongoDB Atlas cluster (or use a self-hosted instance).
#   2. Replace the placeholder below with your connection string.
#   3. Rename this file to .env.local for local development.
#
# The app connects to the database specified in the URI and stores all
# shortened links in a collection named "dsc".

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Discord OAuth – required for "Login with Discord"
#
# Set up:
#   1. Go to https://discord.com/developers/applications
#   2. Create a new application and add an OAuth2 redirect:
#      http://localhost:3000/api/auth/callback/discord (development)
#      https://dscs.ziggymc.me/api/auth/callback/discord (production)
#   3. Copy the Client ID and Client Secret below.

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# NextAuth secret – generate with: openssl rand -base64 32
# Required in production. Can be any random string locally.

NEXTAUTH_SECRET=your_nextauth_secret_here

# The canonical URL of this deployment (used by NextAuth for redirects).
# In production, set this to your actual domain.

NEXTAUTH_URL=http://localhost:3000
