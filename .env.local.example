# Vercel KV (Redis) – required for persistent short-link storage in production.
#
# Set up:
#   1. Create a KV database in your Vercel dashboard (Storage → KV).
#   2. Copy the credentials below from the "Quickstart" tab of your KV database.
#   3. Rename this file to .env.local for local development.
#
# When these variables are NOT set, the app falls back to an in-memory store
# that only persists for the lifetime of the current server process (suitable
# for local development only).

KV_REST_API_URL=
KV_REST_API_TOKEN=
